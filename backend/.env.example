# ============================================
# KB CRM Backend - Environment Variables
# Copy to .env and fill in your values
# DO NOT COMMIT .env FILE TO GIT
# ============================================

# ===========================
# Server Configuration
# ===========================
NODE_ENV=development
PORT=5000

# ===========================
# MongoDB Database
# ===========================
# Local: mongodb://localhost:27017/kb_crm
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/kb_crm
MONGODB_URI=mongodb://localhost:27017/kb_crm

# ===========================
# JWT Authentication
# ===========================
# IMPORTANT: Use a strong secret (min 32 chars) in production
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# ===========================
# CORS
# ===========================
# Comma-separated for multiple origins
# Dev: http://localhost:5173
# Prod: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# ===========================
# Cloudinary (Image Uploads)
# ===========================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===========================
# Email (SMTP)
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=KB Enterprises
EMAIL_FROM_ADDRESS=noreply@kbenterprises.com

# ===========================
# Frontend URL (for email links)
# ===========================
FRONTEND_URL=http://localhost:5173
