# ============================================
# KB CRM Backend - Docker Ignore
# Exclude files not needed in image
# ============================================

# Dependencies (will be installed on server)
node_modules

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Git
.git
.gitignore
.env.*
!.env.example

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md
!package.json

# Tests (not needed in production)
tests/
__tests__/
coverage/
.nyc_output/
jest.config.js
jest.config.cjs
*.test.js
*.spec.js
*.test.ts
*.spec.ts

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-*
*.code-workspace

# Logs
logs/
*.log

# Scripts (dev/migration only)
scripts/

# OS files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# Docker (prevent recursive copy)
Dockerfile
Dockerfile.*
.dockerignore
docker-compose*.yml

# Temporary files
tmp/
temp/
.tmp/
.temp/
*.tmp
*.bak
*.cache

# Build artifacts
dist/
build/
out/

# TypeScript (if applicable)
*.tsbuildinfo
tsconfig.json

# Debug
*.pid
*.seed
pids/

# Optional npm cache
.npm/

# Claude/AI
.claude/

# Archives (backups, exports)
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bz2
